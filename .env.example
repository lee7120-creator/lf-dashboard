# 네이버 API 키 (개인계정 발급 가능). 실제 값은 .env 에 넣으세요(.env 는 git 무시).
# 복사:  cp .env.example .env  후 값 채우기

# ① 검색광고 API — https://searchad.naver.com → 도구 → API 사용 관리
NAVER_AD_API_KEY=
NAVER_AD_SECRET=
NAVER_AD_CUSTOMER_ID=

# ② 데이터랩/쇼핑인사이트 — https://developers.naver.com → 애플리케이션 등록
NAVER_CLIENT_ID=
NAVER_CLIENT_SECRET=
